{
  "name": "mon-parc-it",
  "version": "1.0.0",
  "description": "Gestion de parc informatique - Intune/Azure AD",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch . --ext js,json,env server.js",
    "version:bump": "node -e \"const fs=require('fs'),v=require('./version.json');v.minor++;fs.writeFileSync('./version.json',JSON.stringify(v,null,2)+'\\n');console.log('Version: '+v.major+'.'+v.minor);\""
  },
  "dependencies": {
    "@azure/msal-node": "^2.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "express-session": "^1.19.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "net-snmp": "^3.26.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
