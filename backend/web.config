<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- iisnode : pointe vers le point d'entrée Node.js -->
    <handlers>
      <add name="iisnode"
           path="server.js"
           verb="*"
           modules="iisnode" />
    </handlers>

    <!-- Redirige toutes les requêtes vers server.js -->
    <rewrite>
      <rules>
        <rule name="NodeApp" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Logs iisnode -->
    <iisnode nodeProcessCommandLine="C:\Program Files\nodejs\node.exe"
             loggingEnabled="true"
             logDirectory="iisnode_logs"
             watchedFiles="*.js;.env" />

  </system.webServer>
</configuration>